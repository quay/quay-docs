#!/usr/bin/env bash
set -euo pipefail
rm -rf dist
mkdir -p dist

PRODUCT_ATTR=(-a productname="Project Quay")
BOOK_ATTR=(-a productname="Project Quay" -a toc="left" -d book)

asciidoctor "${PRODUCT_ATTR[@]}" -d book welcome.adoc -D dist -o welcome.html
cp dist/welcome.html dist/index.html

for master in */master.adoc; do
  dir=$(dirname "$master")
  case "$dir" in
    api) out=api_quay ;;
    *) out="$dir" ;;
  esac

  # Directory form: /deploy_red_hat_quay_operator/ (RH docs-style URL)
  mkdir -p "dist/${out}"
  asciidoctor "${BOOK_ATTR[@]}" -a imagesdir=../images "$master" -D "dist/${out}" -o index.html

  # Flat file: /deploy_red_hat_quay_operator.html (existing PR preview links)
  sed 's|src="../images/|src="images/|g; s|href="../images/|href="images/|g' \
    "dist/${out}/index.html" > "dist/${out}.html"
done

cp -a images dist/images
